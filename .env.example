# Local (npm run dev) — use localhost MySQL from docker compose
# Docker Compose sets these for the api container automatically
PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=vuln_lab
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
UPLOAD_DIR=uploads
# Host: often `magick` (IM7). Docker image uses `convert` (Debian IM6).
IMAGEMAGICK_CMD=magick